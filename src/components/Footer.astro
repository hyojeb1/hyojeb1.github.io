---
import siteConfig from '~/site.config'
import SocialLinks from '~/components/SocialLinks.astro'

// 현재 연도를 가져옵니다.
const currentYear = new Date().getFullYear();
// 시작 연도가 2026이므로, 현재가 2026이면 "2026", 그 이후면 "2026–2027" 식으로 표시합니다.
const copyrightYear = currentYear > 2026 ? `2026–${currentYear}` : "2026";
---

<footer
  class="mt-auto pt-9 md:pt-11 grow-0 flex flex-col gap-6 items-center justify-between max-w-full text-foreground/80"
>
  {siteConfig.socialLinks && <SocialLinks socialLinks={siteConfig.socialLinks} />}
  <div class="flex flex-col md:flex-row flex-wrap flex-1 items-center justify-center">
    <span class="my-1">
      {/* 2025 대신 계산된 copyrightYear 변수를 사용합니다 */}
      {siteConfig.author} © {copyrightYear}
    </span>
    <span class="mx-5 hidden md:block"> :: </span>
    <span class="my-1">
      Powered by <a
        class="underline"
        target="_blank"
        rel="noopener noreferrer"
        href="https://astro.build">Astro</a
      >
      & <a
        class="underline"
        target="_blank"
        rel="noopener noreferrer"
        href="https://github.com/stelcodes/multiterm-astro">MultiTerm</a
      >
    </span>
  </div>
</footer>